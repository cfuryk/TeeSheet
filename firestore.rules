rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isAuthed() {
      return request.auth != null;
    }

    function isRoundMember(roundId) {
      return request.auth.uid in get(/databases/$(database)/documents/rounds/$(roundId)).data.memberIds
        || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid;
    }

    function isEventMemberOfRound(roundId) {
      let eventId = get(/databases/$(database)/documents/rounds/$(roundId)).data.eventId;
      return eventId != null
        && request.auth.uid in get(/databases/$(database)/documents/events/$(eventId)).data.memberIds;
    }

    // =========================================================================
    // users/{uid}
    // =========================================================================
    match /users/{uid} {
      allow read: if isAuthed();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();
    }

    // =========================================================================
    // courses/{courseId}
    // =========================================================================
    match /courses/{courseId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // =========================================================================
    // events/{eventId}
    // =========================================================================
    match /events/{eventId} {
      allow read: if isAuthed()
        && (resource.data.isPrivate == false
          || resource.data.createdBy == request.auth.uid
          || request.auth.uid in resource.data.memberIds
          || isAdmin());

      allow create: if isAuthed();

      allow update: if isAuthed()
        && (resource.data.createdBy == request.auth.uid
          || isAdmin()
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberIds', 'handicaps', 'roundIds', 'updatedAt']));

      allow delete: if isAuthed()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // =========================================================================
    // scores/{scoreId}  — top-level golfer score records (handicap history)
    // =========================================================================
    match /scores/{scoreId} {
      allow read: if isAuthed()
        && (request.auth.uid == resource.data.golferId || isAdmin());

      allow create: if isAuthed()
        && request.resource.data.golferId == request.auth.uid;

      allow update: if isAuthed()
        && (resource.data.golferId == request.auth.uid || isAdmin());

      allow delete: if isAuthed()
        && (resource.data.golferId == request.auth.uid || isAdmin());
    }

    // =========================================================================
    // rounds/{roundId}
    // =========================================================================
    match /rounds/{roundId} {
      allow read: if isAuthed()
        && (isAdmin()
          || resource.data.isPrivate == false
          || resource.data.createdBy == request.auth.uid
          || request.auth.uid in resource.data.memberIds
          || (resource.data.eventId != null
              && request.auth.uid in get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.memberIds));

      allow create: if isAuthed();

      allow update: if isAuthed()
        && (isAdmin()
          || resource.data.createdBy == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberIds', 'groupIds', 'status', 'updatedAt']));

      allow delete: if isAuthed()
        && (isAdmin() || resource.data.createdBy == request.auth.uid);

      // =====================================================================
      // rounds/{roundId}/groups/{groupId}
      // =====================================================================
      match /groups/{groupId} {
        allow read: if isAuthed()
          && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId)
            || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid);

        allow create: if isAuthed()
          && get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid;

        allow update: if isAuthed()
          && (isAdmin()
            || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid
            || request.auth.uid in resource.data.golferIds
            || isEventMemberOfRound(roundId));

        allow delete: if isAuthed()
          && (isAdmin()
            || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid);

        // =================================================================
        // rounds/{roundId}/groups/{groupId}/scores/{uid}
        // =================================================================
        match /scores/{uid} {
          allow read: if isAuthed()
            && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId));

          allow create: if isAuthed()
            && (isAdmin()
              || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid
              || isEventMemberOfRound(roundId));

          allow update: if isAuthed()
            && (isAdmin()
              || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid
              || request.auth.uid == uid
              || request.auth.uid in get(/databases/$(database)/documents/rounds/$(roundId)/groups/$(groupId)).data.golferIds);

          allow delete: if isAuthed()
            && (isAdmin()
              || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid
              || request.auth.uid == uid);
        }
      }

      // =====================================================================
      // rounds/{roundId}/sideBets/{sideBetId}
      // =====================================================================
      match /sideBets/{sideBetId} {
        // Any round member or event member can read side bets
        allow read: if isAuthed()
          && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId));

        // Any round member can create a side bet
        allow create: if isAuthed()
          && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId))
          && request.resource.data.createdBy == request.auth.uid;

        // Participants can update (accept/decline/join); creator or admin can cancel/settle
        allow update: if isAuthed()
          && (isAdmin()
            || resource.data.createdBy == request.auth.uid
            || request.auth.uid in resource.data.participantIds
            || request.auth.uid in resource.data.invitedIds);

        allow delete: if isAuthed()
          && (isAdmin() || resource.data.createdBy == request.auth.uid);
      }

      // =====================================================================
      // rounds/{roundId}/messages/{messageId}  — round chat
      // =====================================================================
      match /messages/{messageId} {
        allow read: if isAuthed()
          && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId));

        allow create: if isAuthed()
          && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId))
          && request.resource.data.uid == request.auth.uid;

        allow update, delete: if false;
      }

      // =====================================================================
      // rounds/{roundId}/scores/{uid}  — live scoring subcollection
      // =====================================================================
      match /scores/{uid} {
        // Any round member, event member, or admin can read all scores (leaderboard)
        allow read: if isAuthed()
          && (isAdmin() || isRoundMember(roundId) || isEventMemberOfRound(roundId));

        // Round creator or admin creates the score doc on round start
        allow create: if isAuthed()
          && (isAdmin()
            || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid);

        // Golfer can update their own score while active; creator/admin can always update
        allow update: if isAuthed()
          && (isAdmin()
            || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid
            || (request.auth.uid == uid && resource.data.status == 'active'));

        allow delete: if isAuthed()
          && (isAdmin()
            || get(/databases/$(database)/documents/rounds/$(roundId)).data.createdBy == request.auth.uid);
      }
    }

  }
}
