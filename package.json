{
    "name": "teesheet",
    "private": true,
    "version": "1.2.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --no-eslintrc -c .eslintrc.cjs",
